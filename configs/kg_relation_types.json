{
  "_comment": "관계 타입 정의. code는 입력값, neo4j_type은 Neo4j 엣지 타입",
  "types": [
    {"code": "addressed_by_treatment", "neo4j_type": "ADDRESSED_BY_TREATMENT", "description": "(문제/증상 → 수단) 어떤 방법으로 다뤄짐"},
    {"code": "addressed_to", "neo4j_type": "ADDRESSED_TO", "description": "(메시지/호칭/행위 → 대상자) 말/제품이 누구를 겨냥"},
    {"code": "addresses", "neo4j_type": "ADDRESSES", "description": "(주체/제품/행위 → 문제/요구) 특정 이슈를 다룸/해결함"},
    {"code": "affected_by", "neo4j_type": "AFFECTED_BY", "description": "(대상 → 원인/요인) 무엇의 영향을 받음"},
    {"code": "affects", "neo4j_type": "AFFECTS", "description": "(원인/주체 → 결과/대상) 영향/증가·감소·개선 등 효과 부여"},
    {"code": "applied_by", "neo4j_type": "APPLIED_BY", "description": "(적용된 것/시술/행위 → 수행자) 누가 바름/시술/적용"},
    {"code": "applied_to", "neo4j_type": "APPLIED_TO", "description": "(제품/행위 → 적용 대상/부위/객체) 어디에/무엇에 적용"},
    {"code": "attribute_of", "neo4j_type": "ATTRIBUTE_OF", "description": "(속성 값 → 대상) 그 속성이 누구/무엇의 것인지"},
    {"code": "available_in", "neo4j_type": "AVAILABLE_IN", "description": "(대상 → 포함/패키징/보관/규격) 어디에 들어있거나 어떤 규격/세트로 제공"},
    {"code": "available_to", "neo4j_type": "AVAILABLE_TO", "description": "(행사/제도/제품 → 접근 가능한 사람/대상) 이용/참여 가능 주체"},
    {"code": "belongs_to", "neo4j_type": "BELONGS_TO", "description": "(항목/문서/주제 → 카테고리/영역) 소속/관할/주제 귀속"},
    {"code": "benefits", "neo4j_type": "BENEFITS", "description": "(대상A ↔ 대상B) 혜택 제공/얻음"},
    {"code": "benefits_user", "neo4j_type": "BENEFITS_USER", "description": "(제품/행위 → 사용자) 사용자에게 이익/효익 제공"},
    {"code": "brand_of", "neo4j_type": "BRAND_OF", "description": "(브랜드/제조사 → 제품) 브랜드-제품 귀속"},
    {"code": "caused_by", "neo4j_type": "CAUSED_BY", "description": "(결과/현상 → 원인) 무엇 때문에 발생"},
    {"code": "causes", "neo4j_type": "CAUSES", "description": "(원인 → 결과/반응) 직접적 인과/유발"},
    {"code": "comparison_with", "neo4j_type": "COMPARISON_WITH", "description": "(A ↔ B) 두 대상을 비교/대조/대체 관계로 엮음"},
    {"code": "described_by", "neo4j_type": "DESCRIBED_BY", "description": "(대상/속성 → 서술/표현) 어떤 말/문구로 불리는가"},
    {"code": "describes", "neo4j_type": "DESCRIBES", "description": "(서술/용어/라벨 → 대상/속성) 무엇을 어떻게 묘사/지칭"},
    {"code": "duration_of_use", "neo4j_type": "DURATION_OF_USE", "description": "사용의 얼마나 오래를 표준화"},
    {"code": "experienced_by", "neo4j_type": "EXPERIENCED_BY", "description": "(경험/효과 → 경험자) 누가 경험함"},
    {"code": "experiences", "neo4j_type": "EXPERIENCES", "description": "(경험자 → 경험/효과) 무엇을 경험함"},
    {"code": "frequency_of_use", "neo4j_type": "FREQUENCY_OF_USE", "description": "사용의 얼마나 자주를 표준화"},
    {"code": "gifted_by", "neo4j_type": "GIFTED_BY", "description": "(증여자 → 선물/제품) 선물의 제공"},
    {"code": "gifted_to", "neo4j_type": "GIFTED_TO", "description": "(선물/제품 → 수령자) 선물의 수신"},
    {"code": "has_attribute", "neo4j_type": "HAS_ATTRIBUTE", "description": "(대상 → 속성 값) 색/향/질감/품질/조건 등 보유 특성"},
    {"code": "has_ingredient", "neo4j_type": "HAS_INGREDIENT", "description": "(제품 → 성분/재료) 성분 포함"},
    {"code": "has_instance", "neo4j_type": "HAS_INSTANCE", "description": "(유형/클래스 → 구성원/사례) Y는 X들을 포함"},
    {"code": "has_part", "neo4j_type": "HAS_PART", "description": "(전체 → 부분/구성요소) 포함 관계"},
    {"code": "information_from", "neo4j_type": "INFORMATION_FROM", "description": "(정보/메시지 → 출처/보낸 쪽) 정보의 발신/기원"},
    {"code": "information_to", "neo4j_type": "INFORMATION_TO", "description": "(정보/메시지 → 수신자/대상) 정보의 수신/전달 방향"},
    {"code": "ingredient_of", "neo4j_type": "INGREDIENT_OF", "description": "(성분/재료 → 제품/혼합물) 구성 성분"},
    {"code": "instance_of", "neo4j_type": "INSTANCE_OF", "description": "(개체 → 상위 유형/클래스) X는 Y의 한 사례/종속"},
    {"code": "no_relationship", "neo4j_type": null, "description": "문맥상 두 엔티티 사이에 유의미한 관계가 확인되지 않음 (저장 안함)"},
    {"code": "not_used_by", "neo4j_type": "NOT_USED_BY", "description": "(제품/대상 → 사람/집단) 사용하지 않음/피함"},
    {"code": "owned_by", "neo4j_type": "OWNED_BY", "description": "(대상 → 소유자) 피소유"},
    {"code": "owns", "neo4j_type": "OWNS", "description": "(소유자 → 대상) 소유/보유"},
    {"code": "part_of", "neo4j_type": "PART_OF", "description": "(부분/구성요소 → 전체) 물리/논리적 부분-전체"},
    {"code": "perceived_by", "neo4j_type": "PERCEIVED_BY", "description": "(평가/인상 → 지각자/리뷰어) 누가 그렇게 느꼈는가"},
    {"code": "perceives", "neo4j_type": "PERCEIVES", "description": "(지각자 → 속성/대상에 대한 인상) 어떻게 느끼는가/선호·기호"},
    {"code": "price_of", "neo4j_type": "PRICE_OF", "description": "(대상 → 가격/비용/가치) 금액·가격 정보"},
    {"code": "produced_by", "neo4j_type": "PRODUCED_BY", "description": "(산출물/제품 → 생산 주체) X가 Y에 의해 생산"},
    {"code": "produces", "neo4j_type": "PRODUCES", "description": "(주체 → 산출물/효과) 생산/발생시킴"},
    {"code": "provided_by", "neo4j_type": "PROVIDED_BY", "description": "(서비스/샘플/제품 → 제공 주체) 누가 제공"},
    {"code": "provided_to", "neo4j_type": "PROVIDED_TO", "description": "(제공 주체 → 수혜자/대상) 누구에게 제공"},
    {"code": "purchased_by", "neo4j_type": "PURCHASED_BY", "description": "(상품/서비스 → 구매자) 구매 주체"},
    {"code": "purchases", "neo4j_type": "PURCHASES", "description": "(구매자 → 상품/서비스) 구매 행위"},
    {"code": "recommended_by", "neo4j_type": "RECOMMENDED_BY", "description": "(추천 주체 → 대상/용도) 무엇을/왜 추천했는가"},
    {"code": "recommended_to", "neo4j_type": "RECOMMENDED_TO", "description": "(추천 행위/주체 → 수신자) 누구에게 추천했는가"},
    {"code": "related_to", "neo4j_type": "RELATED_TO", "description": "(A ↔ B) 일반 연관/연결"},
    {"code": "child_of", "neo4j_type": "CHILD_OF", "description": "사용자 간 가족(자식) 구성원"},
    {"code": "parent_of", "neo4j_type": "PARENT_OF", "description": "사용자 간 가족(부모) 구성원"},
    {"code": "family_member_of", "neo4j_type": "FAMILY_MEMBER_OF", "description": "사용자 간 가족 구성원"},
    {"code": "required_by", "neo4j_type": "REQUIRED_BY", "description": "(조건/자원 → 그것을 필요로 하는 대상) 무엇이 이걸 필요로 함"},
    {"code": "requires", "neo4j_type": "REQUIRES", "description": "(과업/제품 → 필요조건/자원/선행요건) 필요/요건/의존성"},
    {"code": "same_entity", "neo4j_type": null, "description": "두 엔티티가 사실상 동일함 (병합용, KG에 저장 안함)"},
    {"code": "sells", "neo4j_type": "SELLS", "description": "(판매 주체 → 상품/서비스) 판매 행위"},
    {"code": "sold_by", "neo4j_type": "SOLD_BY", "description": "(상품/서비스 → 판매 주체/플랫폼) 판매원/판매처"},
    {"code": "targeted_at", "neo4j_type": "TARGETED_AT", "description": "(캠페인/제품/메시지 → 타깃층) 겨냥/호소 대상"},
    {"code": "targeted_by", "neo4j_type": "TARGETED_BY", "description": "(사람/집단 → 타깃팅 주체) 누구에게 타깃됨"},
    {"code": "time_of_use", "neo4j_type": "TIME_OF_USE", "description": "사용의 언제를 표준화"},
    {"code": "treats", "neo4j_type": "TREATS", "description": "(제품/행위 → 증상/문제) 제거/완화/보호 등 처치"},
    {"code": "used_by", "neo4j_type": "USED_BY", "description": "(제품/도구 → 사용자 집단/개인) 누가 사용"},
    {"code": "used_for", "neo4j_type": "USED_FOR", "description": "(도구/제품/방법 → 목적/과업) 용도/목적"},
    {"code": "used_on", "neo4j_type": "USED_ON", "description": "(제품/행위 → 적용되는 시간/장소/표면/맥락) 언제/어디/무엇 위에 사용"},
    {"code": "used_with", "neo4j_type": "USED_WITH", "description": "(대상A ↔ 대상B) 함께/조합 사용"},
    {"code": "uses", "neo4j_type": "USES", "description": "(사용자 → 제품/도구) 무엇을 사용"},
    {"code": "variant_of", "neo4j_type": "VARIANT_OF", "description": "(변형/색상/버전 → 기준 제품/개념) 변형 관계"},
    {"code": "has_keyword", "neo4j_type": "HAS_KEYWORD", "description": "(BEE_ATTR → KEYWORD) BEE 속성에서 추출된 키워드 연결"}
  ],
  "special_edges": {
    "_comment": "메타데이터에서 자동 생성되는 특수 엣지",
    "OFFICIAL_BRAND": {
      "source_field": "brnd_nm",
      "subject": "review_target",
      "object_type": "BRD",
      "sentiment": "NEU",
      "description": "review_target -> brnd_nm(BRD) 연결, 메타데이터에서 자동 생성"
    }
  },
  "unknown_type_policy": "pass_through",
  "_policy_options": ["pass_through", "drop", "warn"],
  "sentiment_values": ["POS", "NEG", "NEU"],
  "sentiment_mapping": {
    "긍정": "POS",
    "부정": "NEG",
    "중립": "NEU"
  }
}
