# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Test, type-check, and coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Build artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment and local config
.env
.env.*
# ...but the placeholder template IS committed (documents the keys; no secrets).
!.env.example

# Logs and local runtime files
*.log
*.pid
*.sqlite3
*.db

# OS / editor files
.DS_Store
.idea/
.vscode/

# Real customer data — NEVER commit (purchase-history backfill output,
# built by scripts/fetch_user_profiles_pg.py from Azure PG). The WHOLE
# directory is ignored so filename variations cannot leak; the script
# refuses to write anywhere else. Consumed via opt-in env override only.
mockdata/real/
