# GraphRapping unified environment file — copy to `.env` and fill in real values.
#
#   cp .env.example .env   # then edit .env (git-ignored; NEVER commit secrets)
#
# Loading is explicit opt-in: the connector scripts call
# src.common.env_file.load_env_file() at startup. Variables already set in the
# shell / CI always win (override=False), so this file only fills the gaps.
# Tests never load .env, so they stay isolated from your local credentials.

# ── Product master: Elasticsearch (ES9) re-extraction backend ──
# Consumed by scripts/fetch_product_catalog_es.py (full export → refresh chain).
ES_CLOUD_URL=https://your-es-host:9243        # ES base URL — no trailing slash, no index
ES_CLOUD_KEY=your-base64-api-key              # sent verbatim as: Authorization: ApiKey <key>
ES_AMORE_INDEX=amore-product-index            # Amore channel (031) product index
ES_INNI_INDEX=innisfree-product-index         # Innisfree channel (036) product index

# ── User profiles: Azure PostgreSQL (purchase-history backfill) ──
# Consumed by scripts/fetch_user_profiles_pg.py. Credentials are resolved from
# os.environ FIRST (these keys), then fall back to the personal-agent .env path
# (--env-file). Set them here to manage everything from one file.
AIBE_DB_URL=your-azure-pg-host                # host only (no scheme, no port)
AIBE_DB_PORT=5432                             # optional (defaults to 5432)
AIBE_DB_NM=your-database-name                 # database name
AIBE_DB_USER=your-db-user                     # read-only user
AIBE_DB_PW=your-db-password                   # password
AIBE_DB_SCHEMA=agent                          # optional search_path schema

# ── GraphRapping Postgres (serving / migrate / full-load / incremental) ──
GRAPHRAPPING_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/graphrapping

# ── Future source conventions (documented only — not yet consumed) ──
# Review-triple re-extraction (IC-R backend, pending source-access confirmation).
#   AWS S3 (boto3) — standard AWS credential chain (env vars OR a shared profile):
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=ap-northeast-2
# AWS_PROFILE=...                             # alternative: named shared profile
#   Snowflake (connector):
# SNOWFLAKE_ACCOUNT=...
# SNOWFLAKE_USER=...
# SNOWFLAKE_PASSWORD=...
# SNOWFLAKE_WAREHOUSE=...
# SNOWFLAKE_DATABASE=...
# SNOWFLAKE_SCHEMA=...
